# ============================================
# CRUSH CANCER & LIVE — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ============================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Stripe ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_SUPPORT_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_SUPPORT_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ---- OpenAI (for AI Assistant — Premium feature) ----
OPENAI_API_KEY=sk-...

# ---- Resend (email notifications) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@crushcancerandlive.app

# ---- UploadThing (document uploads) ----
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=your-app-id
